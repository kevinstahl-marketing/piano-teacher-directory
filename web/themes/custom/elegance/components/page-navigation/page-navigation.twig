{#
/**
 * @file
 * Template for a Page Navigation component.
 *
#}
{%
  embed 'elegance:navbar' with {
    navbar_container_type: 'fluid',
    navbar_theme: 'light',
    navbar_utility_classes: [
      'justify-content-between', 'bg-white', 'shadow-sm',
      'px-0'
    ],
    placement: 'sticky-top',
  }
%}
  {% block branding %}
    {% if page.navbar_branding %}
      {{ page.navbar_branding }}
    {% endif %}
  {% endblock %}

  {% block left %}
    {% if page.navbar_left %}
      <div class="me-auto">
        {{ page.navbar_left }}
      </div>
    {% endif %}
  {% endblock %}

  {% block right %}
    {% if page.navbar_right %}
      <div class="ms-auto">
        {{ page.navbar_right }}
      </div>
    {% endif %}
  {% endblock %}
{% endembed %}
