{#
/**
* @file
* Template for page--404 component.
*/
#}


<!-- 404 Not Found Page -->
<section class="py-5 bg-light min-vh-100 d-flex align-items-center">
    <div class="container" style="max-width: 800px;">
        <div class="text-center">
            <!-- 404 Number -->
            <div class="display-1 fw-bold text-primary mb-4" style="font-size: 8rem; line-height: 1;">
                404
            </div>

            <!-- Heading -->
            <h1 class="mb-4">Page Not Found</h1>

            <!-- Message -->
            <p class="lead text-muted mb-5">
                Sorry, we couldn't find the page you're looking for. It may have been moved or doesn't exist.
            </p>

            <!-- Action Buttons -->
            <div class="d-flex flex-wrap gap-3 justify-content-center">
                <a href="/" class="btn btn-primary btn-lg fw-bold border-2">
                    Go to Homepage
                </a>
                <a href="/teachers" class="btn btn-outline-primary btn-lg fw-bold border-2">
                    Browse Teachers
                </a>
            </div>

            <!-- Decorative Border -->
            <div class="mt-5 pt-5 border-top border-4 border-warning">
                <p class="text-muted small mb-0">
                    Need help? <a href="/contact" class="text-primary text-decoration-none fw-bold">Contact us</a>
                </p>
            </div>
        </div>
    </div>
</section>
