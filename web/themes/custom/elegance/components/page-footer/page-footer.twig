{#
/**
* @file
* Template for a Page Footer component.
*/
#}
{% set footer_attributes = footer_attributes ?: create_attribute() %}
{%
set footer_classes = [
'page__footer',
'bg-light',
'border-top',
'border-4',
'border-primary',
'mt-auto',
]|merge(footer_utility_classes ?: [])
%}

<footer {{ footer_attributes.addClass(footer_classes) }}>
    <div class="container py-5" style="max-width: 1200px;">
        <div class="row g-4">

            {# Brand Column #}
            <div class="col-md-4 col-lg-4">
                <div class="d-flex align-items-center gap-2 mb-3">
                    <div
                    class="d-flex align-items-center justify-content-center bg-primary text-white rounded"
                    style="width: 32px; height: 32px;"
                    aria-hidden="true"
                    >
                    <!-- Book + piano key vibe -->
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">

                        <!-- book -->
                        <path d="M4 5c0-1.1.9-2 2-2h12v18H6c-1.1 0-2-.9-2-2z"></path>
                        <path d="M18 3v18"></path>

                        <!-- piano keys hint -->
                        <line x1="8" y1="8" x2="8" y2="16"></line>
                        <line x1="11" y1="8" x2="11" y2="16"></line>
                        <line x1="14" y1="8" x2="14" y2="16"></line>

                    </svg>
                </div>
                <h4 class="h6 mb-0 fw-bold">Piano Teacher Link</h4>
            </div>

            <p class="text-muted small mb-3">
                Connecting students with exceptional piano instructors for in-person and online lessons.
            </p>

            <p class="text-muted small mb-0">
                Discover teachers by location, experience, and teaching style.
            </p>
        </div>

        {% if page.footer %}
            <div class="col-md-8 col-lg-8">
                <div class="row g-4 align-items-start justify-content-md-end">
                    {{ page.footer }}
                </div>
            </div>
        {% endif %}

        <div class="mt-5 pt-4 border-top border-2 text-center">
            <p class="text-muted small mb-2">
                Piano Teachers Link — Connecting musicians and students.
            </p>
            <p class="text-muted small mb-0">
                &copy; {{ "now"|date("Y") }} Piano Teacher Link. All rights reserved.
            </p>
        </div>
    </div>
</footer>