{#
/**
 * @file
 * Template for a Page Footer component.
 */
#}
{% set footer_attributes = footer_attributes ?: create_attribute() %}
{%
  set footer_classes = [
    'page__footer',
    'bg-light',
    'border-top',
    'border-4',
    'border-primary',
    'mt-auto',
  ]|merge(footer_utility_classes ?: [])
%}

<footer {{ footer_attributes.addClass(footer_classes) }}>
  <div class="container py-5" style="max-width: 1200px;">
    <div class="row g-4">

      {# Brand Column #}
      <div class="col-md-4 col-lg-3">
        <div class="d-flex align-items-center gap-2 mb-3">
          <div
            class="d-flex align-items-center justify-content-center bg-primary text-white rounded"
            style="width: 32px; height: 32px;"
            aria-hidden="true"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 18V5l12-2v13"></path>
              <circle cx="6" cy="18" r="3"></circle>
              <circle cx="18" cy="16" r="3"></circle>
            </svg>
          </div>
          <h4 class="h6 mb-0 fw-bold">Piano Teachers</h4>
        </div>

        <p class="text-muted small mb-3">
          Connecting students with exceptional piano instructors for in-person and online lessons.
        </p>

        <p class="text-muted small mb-0">
          Discover teachers by location, experience, and teaching style.
        </p>
      </div>

      {# Quick Links / actual Drupal footer menu #}
      <div class="col-md-4 col-lg-3">
        <h4 class="h6 mb-3 fw-semibold">Quick Links</h4>
        {% if page.footer %}
          <div class="footer-menu">
            {{ page.footer }}
          </div>
        {% endif %}
      </div>

      {# Support #}
      <div class="col-md-4 col-lg-3">
        <h4 class="h6 mb-3 fw-semibold">Support</h4>
        <ul class="list-unstyled mb-0">
          <li class="mb-2">
            <a href="/contact" class="text-muted text-decoration-none small">Contact Us</a>
          </li>
          <li class="mb-2">
            <a href="/teachers" class="text-muted text-decoration-none small">Browse Teachers</a>
          </li>
          <li class="mb-2">
            <a href="/about" class="text-muted text-decoration-none small">About Us</a>
          </li>
        </ul>
      </div>

      {# Legal #}
      <div class="col-md-4 col-lg-3">
        <h4 class="h6 mb-3 fw-semibold">Legal</h4>
        <ul class="list-unstyled mb-0">
          <li class="mb-2">
            <a href="#" class="text-muted text-decoration-none small">Privacy Policy</a>
          </li>
          <li class="mb-2">
            <a href="#" class="text-muted text-decoration-none small">Terms of Service</a>
          </li>
        </ul>
      </div>

    </div>

    <div class="mt-5 pt-4 border-top border-2 text-center">
      <p class="text-muted small mb-2">
        Piano Teachers Directory — Connecting musicians and students.
      </p>
      <p class="text-muted small mb-0">
        &copy; {{ "now"|date("Y") }} Piano Teachers Directory. All rights reserved.
      </p>
    </div>
  </div>
</footer>