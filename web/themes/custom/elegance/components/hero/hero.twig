{#
/**
* @file
* Template for hero component.
*/
#}


<section class="position-relative overflow-hidden bg-dark text-white">
    {% if hero_image %}
        <!-- Background Image -->
        <div class="position-absolute top-0 start-0 w-100 h-100"
            style="background-image: url('{{ hero_image_url }}'); background-size: cover; background-position: center 40%;">
        </div>
    {% endif %}

    <!-- Overlay -->
    <div class="position-absolute top-0 start-0 w-100 h-100 bg-dark opacity-75"></div>

    <!-- Content -->
    <div class="container position-relative py-5">
        <div class="row">
            <div class="col-lg-8">
  
                {% block hero_above %}
                  {{hero_above}}
                {% endblock %}

                {% if hero_title %}
                    <h1 class="display-3 mb-4">{{ hero_title }}</h1>
                {% endif %}

                {% if hero_subheading %}
                    <p class="lead mb-4">{{ hero_subheading }}</p>
                {% endif %}


                {% block hero_below %}
                  {{hero_below}}
                {% endblock %}


            </div>
        </div>
    </div>
</section>