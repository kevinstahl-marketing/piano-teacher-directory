{#
/**
* @file
* Template for views-view--teacher-directory component.
*/
#}

{% set views_attributes = attributes ?: create_attribute() %}
{% set views_title_attributes = views_title_attributes ?: create_attribute() %}
{% set views_header_attributes = views_header_attributes ?: create_attribute() %}
{% set views_filters_attributes = views_filters_attributes ?: create_attribute() %}
{% set views_rows_attributes = views_rows_attributes ?: create_attribute() %}
{% set views_empty_attributes = views_empty_attributes ?: create_attribute() %}
{% set views_footer_attributes = views_footer_attributes ?: create_attribute() %}
{% set views_attachment_before_attributes = views_attachment_before_attributes ?: create_attribute() %}
{% set views_attachment_after_attributes = views_attachment_after_attributes ?: create_attribute() %}
{% set views_pager_attributes = views_pager_attributes ?: create_attribute() %}
{% set views_more_attributes = views_more_attributes ?: create_attribute() %}
{% set views_feed_icons_attributes = views_feed_icons_attributes ?: create_attribute() %}

{%
set views_classes = [
'view',
'view-' ~ id|clean_class,
'view-id-' ~ id,
'view-display-id-' ~ display_id,
dom_id ? 'js-view-dom-id-' ~ dom_id,
css_name ? 'view-' ~ css_name,
]|merge(view_view_utility_classes ?: [])
%}

{%
set views_filters_classes = [
'view-filters',
]|merge(views_filters_utility_classes ?: [])
%}

{%
set views_rows_classes = [
'view-content',
'row',
'g-4',
]|merge(views_rows_utility_classes ?: [])
%}

{%
set views_pager_classes = [
'pager',
'mt-5',
]|merge(views_pager_utility_classes ?: [])
%}

{% set current_title = header|render|striptags|trim %}
{% set hero_title = 'Teacher Results' %}
{% set found_label = 'Teachers Found' %}

<div {{ views_attributes.addClass(views_classes) }}>

    <section class="position-relative overflow-hidden bg-dark text-white py-5 border-bottom border-4 border-primary">

        {# Background Image #}
        <div class="position-absolute top-0 start-0 w-100 h-100"
            style="background-image: url('https://images.unsplash.com/photo-1446922228752-9b9245ca8aa6?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1920'); background-size: cover; background-position: center;">
        </div>

        {# Dark Overlay #}
        <div class="position-absolute top-0 start-0 w-100 h-100 bg-dark" style="opacity: 0.75;"></div>

        {# Content #}
        <div class="container position-relative py-5" style="max-width: 1200px;">
            <div class="text-center">

                <p class="fw-bold text-primary mb-2">BROWSE TEACHERS</p>

                <h1 class="mb-3">
                    {{ hero_title }}
                </h1>

                <p class="lead mb-4">
                    Browse our directory of experienced music instructors
                </p>

                <a href="/teachers" class="btn btn-outline-light btn-sm">
                    ← Back to All Teachers
                </a>

            </div>
        </div>

    </section>

    {% block views_filters %}
        {% if exposed %}
            <section class="py-4 bg-white border-bottom border-4 border-primary">
                <div class="container" style="max-width: 1200px;">
                    <div {{ views_filters_attributes.addClass(views_filters_classes) }}>
                        {{ exposed }}
                    </div>
                </div>
            </section>
        {% endif %}
    {% endblock %}

    <section class="py-5 bg-light">
        <div class="container" style="max-width: 1200px;">

            <div class="mb-4">
                <p class="fw-bold text-muted mb-0">{{ found_label|upper }}</p>
            </div>

            {% block views_attachment_before %}
                {% if attachment_before %}
                    <div {{ views_attachment_before_attributes.addClass(['attachment', 'attachment-before']) }}>
                        {{ attachment_before }}
                    </div>
                {% endif %}
            {% endblock %}

            {% block views_rows %}
                {% if rows %}
                    <div {{ views_rows_attributes.addClass(views_rows_classes) }}>
                        {{ rows }}
                    </div>
                {% elseif empty %}
                    <div {{ views_empty_attributes.addClass(['view-empty', 'text-center', 'py-5']) }}>
                        {{ empty }}
                    </div>
                {% endif %}
            {% endblock %}

            {% block views_pager %}
                {% if pager %}
                    <div {{ views_pager_attributes.addClass(views_pager_classes) }}>
                        {{ pager }}
                    </div>
                {% endif %}
            {% endblock %}

            {% block views_attachment_after %}
                {% if attachment_after %}
                    <div {{ views_attachment_after_attributes.addClass(['attachment', 'attachment-after']) }}>
                        {{ attachment_after }}
                    </div>
                {% endif %}
            {% endblock %}

            {% block views_more %}
                {% if more %}
                    <div class="mt-4">
                        {{ more }}
                    </div>
                {% endif %}
            {% endblock %}

            {% block views_footer %}
                {% if footer %}
                    <div {{ views_footer_attributes.addClass(['view-footer']) }}>
                        {{ footer }}
                    </div>
                {% endif %}
            {% endblock %}
        </div>
    </section>

</div>