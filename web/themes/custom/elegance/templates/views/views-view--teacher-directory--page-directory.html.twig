<section class="position-relative overflow-hidden bg-dark text-white py-5 border-bottom border-4 border-warning">
    <div class="position-absolute top-0 start-0 w-100 h-100"
        style="background-image: url('https://images.unsplash.com/photo-1446922228752-9b9245ca8aa6?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1920'); background-size: cover; background-position: center;">
    </div>

