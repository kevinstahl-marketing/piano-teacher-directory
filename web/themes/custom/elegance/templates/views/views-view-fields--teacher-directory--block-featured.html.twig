{#
/**
* @file
* Theme override for a single teacher card in the featured homepage view.
*
* Available variables:
* - fields: A dictionary of field objects keyed by field machine name.
*/
#}

<div class="card border-2 h-100 shadow-sm">
    <div class="teacher-card__image border-bottom border-2">
        {{ fields.field_profile_photo.content }}
    </div>

    <div class="card-body d-flex flex-column">
        <div class="teacher-title">
            <h3 class="h5 mb-1">
                {{ fields.title.content }}

            </h3>
        </div>

        {% if fields.field_country.content %}
            <p class="text-muted small mb-2">
                {{ fields.field_country.content }}
            </p>
        {% endif %}

        {% set styles = fields.field_styles.content|raw %}
        {% if styles %}
            <div class="teacher-styles">
                {{ styles }}
            </div>
        {% endif %}

        {% if fields.field_instruments.content %}
  <p class="small mt-2 mb-2">
    <span class="text-body-secondary fw-medium me-1">Instruments:</span>
    <span class="text-muted">{{ fields.field_instruments.content }}</span>
  </p>
{% endif %}

        <div class="flex-grow-1">
            {% if fields.field_bio.content %}
                <p class="teacher-card__bio text-muted small mb-0">
                    {{ fields.field_bio.content }}
                </p>
            {% endif %}
        </div>

        <a href="{{ path('entity.node.canonical', {'node': row._entity.id()}) }}"
            class="btn btn-primary w-100 mt-auto">
            View Profile →
        </a>


    </div>
</div>
