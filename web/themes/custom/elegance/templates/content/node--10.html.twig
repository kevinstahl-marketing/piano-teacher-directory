{#
/**
* @file
* The File Page for "About" - Node 10
*
* Preprocess is run in in theme functions, variables created from core page node
*/
#}

{# HHERO #}

{% if hero %}
    {% include 'elegance:hero' with {
    page: true,
    hero_image: hero.image,
    hero_image_url: hero.image_url,
    hero_title: hero.title,
    hero_subheading: hero.subheading,
    title_attributes: title_attributes,
    hero_above: hero.above,
    hero_below: hero.below,
    } %}
{% endif %}

{# MARQUEE #}
{% if section_1.title %}
    {{ include('elegance:about-mission', {title: section_1.title, body: section_1.body}) }}
{% endif %}


{# HOW IT WORKS #}
{% if featured_section.title %}
    {{ include('elegance:featured-section',{
    title: featured_section.title,
    subheading: featured_section.subheading,
    item_1_body: featured_section.section_1,
    item_2_body: featured_section.section_2,
    item_3_body: featured_section.section_3,
    }) }}
{% endif %}

{# TEACHER CTA #}
{% if teacher_cta %}
    {{ include('elegance:teacher-cta', { teacher_cta: teacher_cta }) }}
{% endif %}

{# STUDENT CTA #}
{% if student_cta %}
    {{ include('elegance:student-cta', { student_cta: student_cta }) }}
{% endif %}