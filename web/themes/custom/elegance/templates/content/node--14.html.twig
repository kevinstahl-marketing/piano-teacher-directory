<!-- Page Header -->
<section class="position-relative overflow-hidden bg-dark text-white py-5 border-bottom border-4 border-warning">
    <!-- Background Image -->
    <div class="position-absolute top-0 start-0 w-100 h-100"
        style="background-image: url('https://images.unsplash.com/photo-1629193886144-e7197ce691ae?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1920'); background-size: cover; background-position: center;">
    </div>

    <!-- Dark Overlay -->
    <div class="position-absolute top-0 start-0 w-100 h-100 bg-dark" style="opacity: 0.8;"></div>

    <!-- Content -->
    <div class="container position-relative py-5" style="max-width: 1200px;">
        <div class="row">
            <div class="col-lg-8 mx-auto text-center">
                <span class="badge bg-warning text-dark px-3 py-2 mb-4 border border-2 border-white">
                    JOIN OUR DIRECTORY
                </span>
                <h1 class="mb-4">Become a Listed Teacher</h1>
                <p class="lead">
                    Share your passion for piano with students in your area. Join our directory and connect with eager learners.
                </p>
            </div>
        </div>
    </div>
</section>

<!-- Benefits Section -->
<section class="py-5 bg-white border-bottom border-4 border-primary">
    <div class="container" style="max-width: 1200px;">
        <h2 class="text-center mb-5">Why Join Our Directory?</h2>

        <div class="row g-4">
            <div class="col-md-4">
                <div class="border-start border-4 border-primary ps-3">
                    <h3 class="h5 mb-3 fw-bold">Reach More Students</h3>
                    <p class="text-muted small">
                        Get discovered by students actively searching for piano instruction in your area.
                    </p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="border-start border-4 border-warning ps-3">
                    <h3 class="h5 mb-3 fw-bold">Build Your Reputation</h3>
                    <p class="text-muted small">
                        Showcase your credentials, teaching style, and experience to attract the right students.
                    </p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="border-start border-4 border-primary ps-3">
                    <h3 class="h5 mb-3 fw-bold">No Listing Fees</h3>
                    <p class="text-muted small">
                        Join our community at no cost. We believe in connecting teachers and students without barriers.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Application Form Section -->
<section class="py-5 bg-light">
    <div class="container" style="max-width: 800px;">

        <!-- Success Message -->
        <div class="alert alert-success border-2 text-center mb-4 d-none" id="teacherSuccessMessage">
            <p class="fw-bold fs-5 mb-2">APPLICATION RECEIVED!</p>
            <p class="mb-2">Thank you for your interest in joining our directory.</p>
            <p class="small text-muted mb-0">
                We'll review your application and get back to you within 3-5 business days.
            </p>
        </div>

        <!-- Application Form -->
        <div class="bg-white border-2 p-4 p-md-5">
            <h2 class="mb-2">Teacher Application</h2>
            <p class="text-muted small mb-4">
                Fill out the form below to apply for listing in our directory. All fields are required.
            </p>

            <form id="teacherApplicationForm">

                <!-- Personal Information Section -->
                <div class="border-start border-4 border-primary ps-3 mb-5">
                    <h3 class="h6 fw-bold mb-4">PERSONAL INFORMATION</h3>

                    <div class="mb-3">
                        <label for="name" class="form-label fw-bold small">Full Name</label>
                        <input type="text" class="form-control form-control-lg border-2" id="name" name="name" required>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label for="email" class="form-label fw-bold small">Email Address</label>
                            <input type="email" class="form-control form-control-lg border-2" id="email" name="email" required>
                        </div>

                        <div class="col-md-6">
                            <label for="phone" class="form-label fw-bold small">Phone Number</label>
                            <input type="tel" class="form-control form-control-lg border-2" id="phone" name="phone" required>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="location" class="form-label fw-bold small">Location (City, State)</label>
                        <input type="text" class="form-control form-control-lg border-2" id="location" name="location" placeholder="e.g., Portland, OR" required>
                    </div>
                </div>

                <!-- Teaching Information Section -->
                <div class="border-start border-4 border-warning ps-3 mb-5">
                    <h3 class="h6 fw-bold mb-4">TEACHING INFORMATION</h3>

                    <div class="mb-3">
                        <label for="experience" class="form-label fw-bold small">Years of Experience</label>
                        <select class="form-select form-select-lg border-2 fw-bold" id="experience" name="experience" required>
                            <option value="">Select experience level</option>
                            <option value="1-3 years">1-3 years</option>
                            <option value="3-5 years">3-5 years</option>
                            <option value="5-10 years">5-10 years</option>
                            <option value="10+ years">10+ years</option>
                            <option value="20+ years">20+ years</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label for="instruments" class="form-label fw-bold small">Instruments Taught</label>
                        <input type="text" class="form-control form-control-lg border-2" id="instruments" name="instruments" placeholder="e.g., Piano, Keyboard" required>
                    </div>

                    <div class="mb-3">
                        <label for="styles" class="form-label fw-bold small">Teaching Styles / Specializations</label>
                        <input type="text" class="form-control form-control-lg border-2" id="styles" name="styles" placeholder="e.g., Classical, Jazz, Contemporary" required>
                    </div>

                    <div class="mb-3">
                        <label for="education" class="form-label fw-bold small">Education / Credentials</label>
                        <input type="text" class="form-control form-control-lg border-2" id="education" name="education" placeholder="e.g., Bachelor's in Music Performance" required>
                    </div>

                    <div class="mb-3">
                        <label for="rate" class="form-label fw-bold small">Hourly Rate</label>
                        <input type="text" class="form-control form-control-lg border-2" id="rate" name="rate" placeholder="e.g., $60/hour" required>
                    </div>

                    <div class="mb-3">
                        <label for="bio" class="form-label fw-bold small">Teaching Philosophy / Bio</label>
                        <textarea class="form-control form-control-lg border-2" id="bio" name="bio" rows="6" placeholder="Tell us about your teaching approach and what makes you unique as an instructor..." style="resize: none;" required></textarea>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold border-2">
                    SUBMIT APPLICATION →
                </button>
            </form>
        </div>

        <!-- Questions Section -->
        <div class="mt-4 p-4 bg-white border-2 text-center">
            <p class="small text-muted mb-0">
                <strong>Questions?</strong> Contact us at
                <a href="/contact" class="text-primary text-decoration-none">info@pianoteachers.com</a>
            </p>
        </div>

    </div>
</section>

<section class="py-5 bg-light">
    <div class="container" style="max-width: 800px;">

        <!-- Success Message -->
        <div class="alert alert-success border-2 text-center mb-4 d-none" id="teacherSuccessMessage">
            <p class="fw-bold fs-5 mb-2">APPLICATION RECEIVED!</p>
            <p class="mb-2">Thank you for your interest in joining our directory.</p>
            <p class="small text-muted mb-0">
                We'll review your application and get back to you within 3-5 business days.
            </p>
        </div>

        <!-- Application Form -->
        <div class="bg-white border-2 p-4 p-md-5">
            <h2 class="mb-2">Teacher Application</h2>
            <p class="text-muted small mb-4">
                Fill out the form below to apply for listing in our directory. All fields are required.
            </p>

            {{ drupal_entity_form('contact_message', values={contact_form: 'teach'}) }}
        </div>

        <!-- Questions Section -->
        <div class="mt-4 p-4 bg-white border-2 text-center">
            <p class="small text-muted mb-0">
                <strong>Questions?</strong> Contact us at
                <a href="/contact" class="text-primary text-decoration-none">info@pianoteachers.com</a>
            </p>
        </div>

    </div>
</section>


